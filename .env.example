# Server
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_PATH=data/startup_intel.db

# LLM Provider: 'groq' (default, free), 'openai', or 'copilot'
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# OPENAI_API_KEY=sk-your-key-here
# COPILOT_API_URL=http://localhost:4141/v1
# GITHUB_TOKEN=

# Ingestion Settings
INGESTION_INTERVAL_MINUTES=1440
# How many companies are processed per click on "Ingest Next Batch".
# 25 is tuned to fit inside Fly.io's 5-minute trial timeout. Raise once
# a credit card has lifted the trial cap.
INGEST_BATCH_LIMIT=25

# Monday.com Integration
# Get token: monday.com → Avatar → Admin → API
# Board ID: visible in the board URL (e.g. monday.com/boards/1234567890)
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
# Optional: custom column mapping (JSON). Default mapping handles common layouts.
# MONDAY_COLUMN_MAP={"Name":"name","Founder":"founder_name","Co-Founder":"cofounder_name"}

# LinkedIn Ingestion
# No API key needed — uses free Google News + DuckDuckGo search.
# Best path for reliable LinkedIn post URLs: Monday.com columns
# (Founder Posts / Co-Founder Posts / Company Posts) or a manual CSV
# (see data/manual_posts.sample.csv and MONDAY_SETUP.md).

# Newsletter Ingestion (Gmail IMAP)
# Create a Gmail, enable 2FA, create App Password at myaccount.google.com/apppasswords
NEWSLETTER_EMAIL=
NEWSLETTER_APP_PASSWORD=
NEWSLETTER_IMAP_HOST=imap.gmail.com

# Twitter/X API (optional, for future use)
TWITTER_BEARER_TOKEN=
